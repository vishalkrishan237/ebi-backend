{
  "name": "elite-battle-india-backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24 <25"
  },
  "scripts": {
    "build": "node ./build.mjs",
    "start": "node index.js",
    "migrate": "node --env-file-if-exists=.env ./run-sql-migrations.mjs",
    "db:push": "node --env-file-if-exists=.env ./node_modules/drizzle-kit/bin.cjs push --config ./drizzle.config.ts",
    "db:push:force": "node --env-file-if-exists=.env ./node_modules/drizzle-kit/bin.cjs push --force --config ./drizzle.config.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "drizzle-orm": "^0.45.2",
    "express": "^5.1.0",
    "express-session": "^1.19.0",
    "pg": "^8.20.0",
    "pino": "^9.14.0",
    "pino-http": "^10.5.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/express-session": "^1.19.0",
    "@types/node": "^25.3.3",
    "@types/pg": "^8.18.0",
    "drizzle-kit": "^0.31.9",
    "esbuild": "0.25.8",
    "esbuild-plugin-pino": "^2.3.3",
    "pino-pretty": "^13.1.2",
    "thread-stream": "3.1.0",
    "typescript": "~5.9.2"
  }
}
