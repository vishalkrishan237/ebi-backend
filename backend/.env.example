SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-with-your-supabase-service-role-key
DATABASE_URL=postgresql://postgres:password@db.example.supabase.co:5432/postgres?sslmode=require
SESSION_SECRET=replace-with-a-long-random-string
NODE_ENV=production
FRONTEND_ORIGIN=https://your-frontend-project.vercel.app
CORS_ORIGINS=https://your-frontend-project.vercel.app
PORT=10000
LOG_LEVEL=info
