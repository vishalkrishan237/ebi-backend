DATABASE_URL=postgresql://postgres:password@your-db-host.example.com:5432/postgres
SESSION_SECRET=replace-with-a-long-random-string
NODE_ENV=production
FRONTEND_ORIGIN=https://your-frontend-project.example.com
CORS_ORIGINS=https://your-frontend-project.example.com
PORT=10000
LOG_LEVEL=info
DB_CONNECT_MAX_ATTEMPTS=8
DB_CONNECT_RETRY_DELAY_MS=5000
